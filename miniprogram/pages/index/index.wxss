/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background: linear-gradient(to bottom, #eff6ff, #ffffff);
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-text {
  color: #6b7280;
  font-size: 28rpx;
}

/* 统计卡片 */
.stats-container {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.stat-card {
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  margin: 0 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #1f2937;
}

.stat-card.stat-green .stat-number {
  color: #16a34a;
}

.stat-card.stat-red .stat-number {
  color: #dc2626;
}

.stat-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

/* 数据校验 */
.validation-card {
  background: #fefce8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.validation-text {
  font-size: 26rpx;
  color: #854d0e;
}

.validation-warning {
  color: #ea580c;
  margin-left: 8rpx;
}

.btn-clear {
  color: #dc2626;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid #dc2626;
  border-radius: 8rpx;
}

.confirm-buttons {
  display: flex;
  gap: 16rpx;
}

.btn-confirm {
  background: #dc2626;
  color: #ffffff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.btn-cancel {
  background: #e5e7eb;
  color: #374151;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

/* 站点统计 */
.section-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  padding: 24rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
}

.section-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-left: 16rpx;
}

.station-list {
  max-height: 800rpx;
}

.station-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.station-item:last-child {
  border-bottom: none;
}

.station-name {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.station-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
}

.station-stats .total {
  font-weight: bold;
  color: #1f2937;
}

.station-stats .in-warranty {
  color: #16a34a;
  background: #dcfce7;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.station-stats .out-warranty {
  color: #dc2626;
  background: #fee2e2;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.station-stats .rate {
  color: #6b7280;
  min-width: 80rpx;
  text-align: right;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #9ca3af;
}

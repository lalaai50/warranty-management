/* pages/query/query.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background: linear-gradient(to bottom, #eff6ff, #ffffff);
}

/* 搜索卡片 */
.search-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.search-header {
  margin-bottom: 24rpx;
}

.search-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
}

.search-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.search-area {
  display: flex;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 160rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #3b82f6;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
}

/* 错误提示 */
.error-card {
  background: #fee2e2;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.error-text {
  color: #dc2626;
  font-size: 26rpx;
}

/* 状态汇总卡片 */
.summary-card {
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.summary-card.summary-green {
  background: #dcfce7;
  border: 2rpx solid #22c55e;
}

.summary-card.summary-red {
  background: #fee2e2;
  border: 2rpx solid #ef4444;
}

.summary-card.summary-orange {
  background: #ffedd5;
  border: 2rpx solid #f97316;
}

.summary-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
}

.summary-green .summary-title { color: #16a34a; }
.summary-red .summary-title { color: #dc2626; }
.summary-orange .summary-title { color: #ea580c; }

.summary-desc {
  font-size: 26rpx;
  margin-top: 8rpx;
  display: block;
}

.summary-green .summary-desc { color: #15803d; }
.summary-red .summary-desc { color: #b91c1c; }
.summary-orange .summary-desc { color: #c2410c; }

/* 设备分类 */
.device-groups {
  margin-top: 20rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.device-group {
  margin-bottom: 16rpx;
}

.device-group:last-child {
  margin-bottom: 0;
}

.group-title {
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: block;
}

.group-green .group-title { color: #16a34a; }
.group-red .group-title { color: #dc2626; }

.device-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.device-tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.tag-green {
  background: #dcfce7;
  color: #16a34a;
}

.tag-red {
  background: #fee2e2;
  color: #dc2626;
}

/* 结果列表 */
.results-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.results-header {
  padding: 24rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.results-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
}

.result-list {
  padding: 0 24rpx;
}

.result-item {
  position: relative;
  padding: 24rpx 0;
  padding-left: 16rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.result-item:last-child {
  border-bottom: none;
}

.status-bar {
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 3rpx;
}

.bar-green { background: #22c55e; }
.bar-red { background: #ef4444; }

.result-content {
  padding-left: 16rpx;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-badge {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.badge-green {
  background: #dcfce7;
  color: #16a34a;
}

.badge-red {
  background: #fee2e2;
  color: #dc2626;
}

.days-text {
  font-size: 24rpx;
  font-weight: 500;
}

.days-green { color: #16a34a; }
.days-red { color: #dc2626; }

.station-info {
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.station-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
}

.station-location {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.device-info {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  margin-bottom: 8rpx;
}

.info-label {
  font-size: 24rpx;
  color: #6b7280;
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 24rpx;
  color: #1f2937;
  flex: 1;
}

.info-value.mono {
  font-family: monospace;
  font-size: 22rpx;
}

.warranty-info {
  padding-top: 16rpx;
  border-top: 1rpx solid #e5e7eb;
}

.warranty-label {
  font-size: 24rpx;
  color: #6b7280;
}

.warranty-value {
  font-size: 24rpx;
  color: #1f2937;
}

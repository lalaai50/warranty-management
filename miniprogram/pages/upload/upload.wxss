/* pages/upload/upload.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background: linear-gradient(to bottom, #eff6ff, #ffffff);
}

/* 上传卡片 */
.upload-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.upload-header {
  margin-bottom: 30rpx;
}

.upload-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
}

.upload-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.upload-area {
  border: 2rpx dashed #d1d5db;
  border-radius: 12rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  background: #f9fafb;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #3b82f6;
}

/* 上传结果 */
.upload-result {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 8rpx;
}

.upload-result.success {
  background: #dcfce7;
}

.upload-result.error {
  background: #fee2e2;
}

.result-text {
  font-size: 26rpx;
}

.upload-result.success .result-text {
  color: #16a34a;
}

.upload-result.error .result-text {
  color: #dc2626;
}

/* 文件列表 */
.files-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.files-header {
  padding: 24rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.files-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
}

.files-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.file-list {
  padding: 0 24rpx;
}

.file-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.file-item:last-child {
  border-bottom: none;
}

.file-info {
  flex: 1;
  min-width: 0;
}

.file-name {
  font-size: 28rpx;
  color: #1f2937;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-meta {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
  display: block;
}

.btn-delete {
  padding: 16rpx;
  font-size: 32rpx;
}

.delete-confirm {
  display: flex;
  gap: 16rpx;
}

.btn-delete-confirm {
  background: #dc2626;
  color: #ffffff;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

.btn-cancel {
  background: #e5e7eb;
  color: #374151;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #9ca3af;
}
